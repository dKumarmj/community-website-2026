---
const text = "DEVELOP // DESIGN // DEPLOY // REPEAT // UMBRACO INDIA // ";
---

<section class="relative w-full overflow-hidden py-4 bg-primary text-black border-y-4 border-black dark:border-white -rotate-1 scale-105 z-40 mb-16 md:mb-24 shadow-brutal-black dark:shadow-brutal-white">
  <div class="animate-marquee whitespace-nowrap flex">
    <span class="text-3xl md:text-5xl font-display font-black mx-4">{text.repeat(3)}</span>
    <span class="text-3xl md:text-5xl font-display font-black mx-4">{text.repeat(3)}</span>
  </div>
  <style>
    .animate-marquee {
      animation: marquee 20s linear infinite;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>
</section>

