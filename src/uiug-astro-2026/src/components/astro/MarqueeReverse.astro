---
const text = "HIGH FIVE YOU ROCK // H5YR // OPEN SOURCE // COMMUNITY // FRIENDLY CMS // ";
---

<section class="relative w-full overflow-hidden py-3 bg-black dark:bg-white text-white dark:text-black border-y-4 border-white dark:border-black rotate-2 scale-110 z-30 -my-12 shadow-brutal-yellow dark:shadow-brutal-red mix-blend-normal pointer-events-none select-none">
  <div class="animate-marquee-reverse whitespace-nowrap flex">
    <span class="text-2xl md:text-4xl font-display font-black mx-4">{text.repeat(4)}</span>
    <span class="text-2xl md:text-4xl font-display font-black mx-4">{text.repeat(4)}</span>
  </div>
  <style>
    .animate-marquee-reverse {
      animation: marquee-reverse 25s linear infinite;
    }
    @keyframes marquee-reverse {
      0% { transform: translateX(-50%); }
      100% { transform: translateX(0); }
    }
  </style>
</section>

